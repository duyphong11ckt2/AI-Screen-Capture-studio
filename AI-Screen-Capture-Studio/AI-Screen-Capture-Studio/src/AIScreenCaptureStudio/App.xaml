<Application x:Class="AIScreenCaptureStudio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AIScreenCaptureStudio.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Dark.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:InverseBoolConverter x:Key="InverseBool" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:ConfidenceToBrushConverter x:Key="ConfidenceToBrush" />
            <conv:ConfidencePercentConverter x:Key="ConfidencePercent" />
            <conv:EnumToBoolConverter x:Key="EnumToBool" />
            <conv:ArrowGeometryConverter x:Key="ArrowGeometry" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
