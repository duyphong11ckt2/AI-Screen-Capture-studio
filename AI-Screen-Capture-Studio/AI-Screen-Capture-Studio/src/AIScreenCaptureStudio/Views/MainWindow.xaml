<Window x:Class="AIScreenCaptureStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="AI Screen Capture Studio"
        Width="1" Height="1"
        WindowStyle="None" ShowInTaskbar="False"
        Visibility="Hidden" AllowsTransparency="True" Background="Transparent">
    <Grid>
        <tb:TaskbarIcon x:Name="Tray"
                        ToolTipText="AI Screen Capture Studio"
                        IconSource="pack://application:,,,/Resources/app.ico">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Capture Full Screen" Command="{Binding CaptureFullScreenCommand}"
                              InputGestureText="PrtScn" />
                    <MenuItem Header="Capture Region…" Command="{Binding CaptureRegionCommand}"
                              InputGestureText="Ctrl+Shift+S" />
                    <MenuItem Header="Capture Active Window" Command="{Binding CaptureActiveWindowCommand}"
                              InputGestureText="Ctrl+Alt+S" />
                    <Separator />
                    <MenuItem Header="History…" Command="{Binding OpenHistoryCommand}" />
                    <MenuItem Header="Settings…" Command="{Binding OpenSettingsCommand}" />
                    <Separator />
                    <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
