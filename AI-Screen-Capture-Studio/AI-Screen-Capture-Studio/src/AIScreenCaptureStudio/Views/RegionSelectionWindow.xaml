<Window x:Class="AIScreenCaptureStudio.Views.RegionSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        Topmost="True" WindowStartupLocation="Manual"
        Background="#55000000" Cursor="Cross"
        Loaded="OnLoaded" KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseDown" MouseMove="OnMouseMove" MouseLeftButtonUp="OnMouseUp">
    <Canvas x:Name="Root">
        <Border x:Name="SelectionBox" Visibility="Collapsed"
                BorderBrush="#FF4C8DFF" BorderThickness="2" Background="#224C8DFF" />
        <TextBlock x:Name="Hint" Foreground="White" FontSize="14" Margin="0"
                   Text="Drag to select a region · Esc to cancel" />
    </Canvas>
</Window>
